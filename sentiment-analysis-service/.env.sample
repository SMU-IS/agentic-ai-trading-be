LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# LLM Configuration (Gemini is primary, others optional)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
LARGE_LANGUAGE_MODEL=gemini-2.5-flash-lite
TEXT_EMBEDDING_MODEL=text-embedding-004
TEMPERATURE=0.7

# Groq (primary LLM provider for sentiment analysis)
GROQ_API_KEY=your-groq-api-key
LARGE_LANGUAGE_MODEL_LLAMA=llama-3.3-70b-versatile

# Optional: Ollama (if using local models)
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: OpenAI (if using OpenAI models)
# OPEN_AI_API_KEY=your-openai-api-key

STORAGE_PROVIDER=your-storage-provider
QDRANT_URL=your-qdrant-url

MAX_COMPLETION_TOKEN=1000

REDIS_URL=redis://redis:6379
REDIS_QUEUE_NAME=raw_news_queue

